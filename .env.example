# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173

# ── Database (PostgreSQL) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=                          # required
DB_DATABASE=booking_service_dev
DB_LOGGING=true
DB_SSL=false

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-32-plus-char-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-32-plus-char-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Security ─────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Email / Frontend URLs ────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password
FRONTEND_EMAIL_VERIFY_URL=http://localhost:5173/verify-email
